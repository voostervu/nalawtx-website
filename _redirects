# Netlify _redirects file
# Purpose: Canonicalize URLs by 301-redirecting all .html versions to clean URLs
# This prevents Google from seeing two versions of the same page (canonicalization)
# Last updated: 2026-05-14

# Index files → folder root
/index.html                       /                              301!
/blog/index.html                  /blog/                         301!
/practice/index.html              /practice/                     301!
/attorneys/index.html             /attorneys/                    301!
/locations/index.html             /locations/                    301!
/intersections/index.html         /intersections/                301!
/guides/index.html                /guides/                       301!
/es/index.html                    /es/                           301!
/es/practice/index.html           /es/practice/                  301!
/vi/index.html                    /vi/                           301!
/vi/practice/index.html           /vi/practice/                  301!

# Root-level .html pages → clean URL
/:slug.html                       /:slug                         301!

# Folder-level .html pages → clean URL
/practice/:slug.html              /practice/:slug                301!
/practice/subtopics/:slug.html    /practice/subtopics/:slug      301!
/locations/:slug.html             /locations/:slug               301!
/intersections/:slug.html         /intersections/:slug           301!
/attorneys/:slug.html             /attorneys/:slug               301!
/blog/:slug.html                  /blog/:slug                    301!
/guides/:slug.html                /guides/:slug                  301!
/es/:slug.html                    /es/:slug                      301!
/es/practice/:slug.html           /es/practice/:slug             301!
/vi/:slug.html                    /vi/:slug                      301!
/vi/practice/:slug.html           /vi/practice/:slug             301!

